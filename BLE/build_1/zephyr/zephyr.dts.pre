# 1 "E:/projects/DevelopmentLevelCode/NRFBOARD/boards/Fervid/WrieLessPotentialDetector_Nrf52832/WrieLessPotentialDetector_Nrf52832-pinctrl.dtsi" 1
&pinctrl {
    uart0_default: uart0_default {
        group1 {
            psels = <((((((0) * 32U) + (27)) & 0x1FFU) << 0U) | ((0U & 0xFFU) << 24U))>,
                    <((((((0) * 32U) + (26)) & 0x1FFU) << 0U) | ((1U & 0xFFU) << 24U))>;
        };
    };

    uart0_sleep: uart0_sleep {
        group1 {
            psels = <((((((0) * 32U) + (27)) & 0x1FFU) << 0U) | ((0U & 0xFFU) << 24U))>,
                    <((((((0) * 32U) + (26)) & 0x1FFU) << 0U) | ((1U & 0xFFU) << 24U))>;
            low-power-enable;
        };
    };
};
# 4 "E:/projects/DevelopmentLevelCode/NRFBOARD/boards/Fervid/WrieLessPotentialDetector_Nrf52832/WrieLessPotentialDetector_Nrf52832.dts" 2

/ {
 model = "WrieLessPotentialDetector_Nrf52832";
 compatible = "Fervid,WrieLessPotentialDetector-Nrf52832";

 chosen {
  zephyr,sram = &sram0;
  zephyr,flash = &flash0;
  zephyr,code-partition = &slot0_partition;

  zephyr,console = &uart0;
  zephyr,shell-uart = &uart0;
 };
  Warning {
  compatible = "gpio-leds";
  Buzzer: Buzzer { gpios = <&gpio0 4 (0 << 0)>; };
  label = "Buzzer";
 };
 range_Manual {
  compatible = "gpio-leds";
  rangeManual0: rangeManual0 { gpios = <&gpio0 20 (0 << 0)>; };
  rangeManual1: rangeManual1 { gpios = <&gpio0 19 (0 << 0)>; };
  rangeManual2: rangeManual2 { gpios = <&gpio0 18 (0 << 0)>; };
  rangeManual3: rangeManual3 { gpios = <&gpio0 17 (0 << 0)>; };
  rangeManual4: rangeManual4 { gpios = <&gpio0 16 (0 << 0)>; };
  rangeManual5: rangeManual5 { gpios = <&gpio0 15 (0 << 0)>; };
  rangeManual6: rangeManual6 { gpios = <&gpio0 14 (0 << 0)>; };
  rangeManual7: rangeManual7 { gpios = <&gpio0 13 (0 << 0)>; };
  rangeManual8: rangeManual8 { gpios = <&gpio0 12 (0 << 0)>; };
  rangeManual9: rangeManual9 { gpios = <&gpio0 11 (0 << 0)>; };
  rangeManual10: rangeManual10 { gpios = <&gpio0 10 (0 << 0)>; };
  rangeManual11: rangeManual11 { gpios = <&gpio0 9 (0 << 0)>; };
  label = "Manual Range Selector";
 };

 range_selIC {
  compatible = "gpio-leds";
  range_selIC0: range_selIC0 { gpios = <&gpio0 3 (0 << 0)>; };
  range_selIC1: range_selIC1 { gpios = <&gpio0 2 (0 << 0)>; };
  range_selIC2: range_selIC2 { gpios = <&gpio0 1 (0 << 0)>; };
  range_selIC3: range_selIC3 { gpios = <&gpio0 0 (0 << 0)>; };
  label = "Slection IC";
 };

 status_pins {
  compatible = "gpio-leds";
  lowbat: lowbat {
   gpios = <&gpio0 5 (1 << 0)>;
   label = "Low Battery";
  };
  charge: charge {
   gpios = <&gpio0 6 (1 << 0)>;
   label = "Charging Status";
  };
  BLEMODE: BLEMODE {
   gpios = <&gpio0 7 (1 << 0)>;
   label = "Selection mode";
  };
 };

};
&clock {
    status = "okay";
    hfclk {
        status = "okay";
        clock-frequency = <32000000>;
    };
    lfclk {
        status = "okay";
        source = "rc";
    };
};

&adc {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;

    BeforeLCCh: channel@7 {
        reg = <7>;
        zephyr,gain = "ADC_GAIN_1_6";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time =
            <((((1)) << 14) | ((20) & ((1UL << (14)) - 1UL)))>;
        zephyr,input-positive = <7>;

    };
    AfterLCCh: channel@6 {
        reg = <6>;
        zephyr,gain = "ADC_GAIN_1_6";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time =
            <((((1)) << 14) | ((20) & ((1UL << (14)) - 1UL)))>;
        zephyr,input-positive = <6>;

    };
    BatteryCh: channel@5 {
        reg = <5>;
        zephyr,gain = "ADC_GAIN_1_6";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time =
            <((((1)) << 14) | ((20) & ((1UL << (14)) - 1UL)))>;
        zephyr,input-positive = <5>;

    };
};

&gpio0 {
 status = "okay";
};

&gpiote {
 status = "okay";
};

&comp {
 status = "okay";
};

&temp {
 status = "disabled";
};

&uart0 {
 status = "okay";
 current-speed = <115200>;
 pinctrl-0 = <&uart0_default>;
 pinctrl-1 = <&uart0_sleep>;
 pinctrl-names = "default", "sleep";
};
&flash0 {
 partitions {
  compatible = "fixed-partitions";
  #address-cells = <1>;
  #size-cells = <1>;

  boot_partition: partition@0 {
   label = "mcuboot";
   reg = <0x00000000 ((48) * 1024)>;
  };

  slot0_partition: partition@c000 {
   label = "image-0";
   reg = <0x0000c000 ((220) * 1024)>;
  };

  slot1_partition: partition@43000 {
   label = "image-1";
   reg = <0x00043000 ((220) * 1024)>;
  };

  storage_partition: partition@7a000 {
   label = "storage";
   reg = <0x0007a000 ((24) * 1024)>;
  };
 };
};
